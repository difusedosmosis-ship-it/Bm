generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CONSUMER
  VENDOR
  ADMIN
}

enum KycStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum RequestMode {
  MATCHED
  CHOOSE
}

enum RequestStatus {
  CREATED
  DISPATCHING
  OFFERED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TxStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  role         Role
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  fullName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendorProfile VendorProfile?

  consumerRequests Request[] @relation("ConsumerRequests")

  reviewsGiven Review[] @relation("ReviewsByConsumer")
  reviewsGot   Review[] @relation("ReviewsForVendor")

  ledgerEntries WalletLedger[]
  transactions  Transaction[]
}

model VendorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String?
  city         String?

  /// ✅ NEW: Vendor geo for proximity search / dispatch
  lat Float?
  lng Float?

  coverageKm Int     @default(10)
  isOnline   Boolean @default(false)

  kycStatus KycStatus @default(DRAFT)
  kycNote   String?

  services       VendorService[]
  kycSubmissions KycSubmission[]
  dispatchOffers DispatchOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// ✅ Helpful indexes for nearby search filters
  @@index([city])
  @@index([isOnline])
  @@index([kycStatus])
  @@index([lat, lng])
}

model KycSubmission {
  id       String @id @default(cuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  idDocUrl       String?
  selfieUrl      String?
  businessDocUrl String?
  skillProofUrl  String?

  status       KycStatus @default(SUBMITTED)
  reviewerNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  kind      String   @default("PHYSICAL") // PHYSICAL | BOOKING (future)
  createdAt DateTime @default(now())

  vendorServices VendorService[]
}

model VendorService {
  id       String @id @default(cuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  title       String
  pricingType String  @default("from") // fixed | from | quote
  priceFrom   Int?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([categoryId])
}

model Request {
  id String @id @default(cuid())

  consumerId String
  consumer   User @relation("ConsumerRequests", fields: [consumerId], references: [id], onDelete: Cascade)

  mode        RequestMode
  city        String
  category    String
  description String
  urgency     String @default("normal") // normal | urgent

  lat Float
  lng Float

  chosenVendorId String?
  status         RequestStatus @default(CREATED)

  acceptedVendorId String?
  acceptedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers  DispatchOffer[]
  reviews Review[]

  @@index([consumerId])
  @@index([city])
  @@index([lat, lng])
}

model DispatchOffer {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  status    OfferStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([vendorId])
  @@index([status])
  @@index([expiresAt])
}

model Review {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  consumerId String
  consumer   User @relation("ReviewsByConsumer", fields: [consumerId], references: [id], onDelete: Cascade)

  vendorId   String
  vendorUser User @relation("ReviewsForVendor", fields: [vendorId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([consumerId])
  @@index([vendorId])
}

model WalletLedger {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount   Int // +credit, -debit
  currency String @default("NGN")
  reason   String
  refType  String?
  refId    String?

  createdAt DateTime @default(now())

  @@index([userId])
}

model Transaction {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int
  currency    String   @default("NGN")
  status      TxStatus @default(PENDING)
  provider    String?
  providerRef String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
